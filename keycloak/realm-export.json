{
  "realm": "patient-risk",
  "enabled": true,
  "defaultSignatureAlgorithm": "RS256",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,

  "clients": [
    {
      "clientId": "patient-risk-agent",
      "name": "Patient Risk Runtime Agent",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "agent-secret-change-in-prod",
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email", "roles"],
      "optionalClientScopes": ["mcp-scopes"],
      "protocolMappers": [
        {
          "name": "groups-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "sub-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.info.token.claim": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "sub",
            "jsonType.label": "String",
            "user.attribute": "id"
          }
        },
        {
  "name": "oid-mapper",
  "protocol": "openid-connect",
  "protocolMapper": "oidc-usermodel-property-mapper",
  "config": {
    "user.info.token.claim": "true",
    "userinfo.token.claim": "true",
    "id.token.claim": "true",
    "access.token.claim": "true",
    "claim.name": "oid",
    "jsonType.label": "String",
    "user.attribute": "id"
  }
},
        {
          "name": "scp-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.value": "mcp.vitals.read mcp.labs.read mcp.meds.read mcp.notes.read",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "scp",
            "userinfo.token.claim": "false"
          }
        }
      ]
    }
  ],

  "clientScopes": [
    {
      "name": "mcp-scopes",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" }
    }
  ],

  "groups": [
    { "name": "grp-clinical-viewer", "path": "/grp-clinical-viewer" },
    { "name": "grp-physician",       "path": "/grp-physician" },
    { "name": "grp-case-manager",    "path": "/grp-case-manager" }
  ],

  "users": [
    {
      "username": "nurse-test",
      "enabled": true,
      "email": "nurse@test.com",
      "firstName": "Test",
      "lastName": "Nurse",
      "credentials": [{ "type": "password", "value": "test123", "temporary": false }],
      "groups": ["grp-clinical-viewer"]
    },
    {
      "username": "doctor-test",
      "enabled": true,
      "email": "doctor@test.com",
      "firstName": "Test",
      "lastName": "Doctor",
      "credentials": [{ "type": "password", "value": "test123", "temporary": false }],
      "groups": ["grp-physician"]
    },
    {
      "username": "casemanager-test",
      "enabled": true,
      "email": "casemanager@test.com",
      "firstName": "Test",
      "lastName": "CaseManager",
      "credentials": [{ "type": "password", "value": "test123", "temporary": false }],
      "groups": ["grp-case-manager"]
    }
  ]
}
