# Copy to .env and fill real values. .env is gitignored; this file is committed.

# --- TimescaleDB (vitals) ---
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5433
TIMESCALE_DB=vitals
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=changeme
VITALS_DB_URL=postgresql://postgres:changeme@localhost:5433/vitals

# --- Postgres (labs_diagnoses + medications_interactions) ---
CLINICAL_HOST=localhost
CLINICAL_PORT=5434
CLINICAL_DB=clinical
CLINICAL_USER=postgres
CLINICAL_PASSWORD=changeme
CLINICAL_DB_URL=postgresql://postgres:changeme@localhost:5434/clinical

# --- Qdrant (clinical_notes_search) ---
QDRANT_URL=http://localhost:6333

# --- Embedding model (MUST match loader + vector_connector exactly) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Synthea (determinism) ---
SYNTHEA_SEED=42
SYNTHEA_PATIENT_COUNT=31

# --- Auth / JWT (Keycloak realm: patient-risk) ---
JWKS_URL=http://localhost:8080/realms/patient-risk/protocol/openid-connect/certs
JWT_AUDIENCE=patient-risk
# Layer-2 Fixed Core (Jul 2): flip on once Keycloak tokens carry real scopes
AUTH_VERIFY_SIGNATURE=false
# Require Bearer on every MCP call (false = POC-friendly anonymous access)
AUTH_ALLOW_ANONYMOUS=false

# --- Self-healing (connector retry; Jul 7) ---
SELF_HEAL_MAX_ATTEMPTS=3

# --- Runtime agent → MCP server URLs (Person B agent reads these) ---
# Host-run agent: use localhost. Dockerised agent: use host.docker.internal:800x
# (host.docker.internal does NOT resolve from a process running on the host).
VITALS_MCP_URL=http://localhost:8001/mcp
LABS_MCP_URL=http://localhost:8002/mcp
MEDS_MCP_URL=http://localhost:8003/mcp
NOTES_MCP_URL=http://localhost:8004/mcp

# --- Platform (Person B — used by docker compose up) ---
KEYCLOAK_CLIENT_SECRET=agent-secret-change-in-prod
OPENAI_API_KEY=
NEXTAUTH_SECRET=change-me-in-prod
